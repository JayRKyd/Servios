PORT=4000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect — your platform URL for onboarding redirects
WEB_URL=http://localhost:3000

# Algolia (admin key — never expose client-side)
# https://dashboard.algolia.com → API Keys
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=

# Sync secret — must match SYNC_SECRET in apps/web/.env.local
SYNC_SECRET=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
NODE_ENV=development
