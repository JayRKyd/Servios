EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:3000

# Algolia Search (read-only search key)
# https://dashboard.algolia.com → API Keys
EXPO_PUBLIC_ALGOLIA_APP_ID=
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=

# Mapbox — https://account.mapbox.com/access-tokens/
# Required for map view — needs Expo Dev Build (not Expo Go)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Expo project ID — https://expo.dev → project → settings
# Required for push notifications
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id
